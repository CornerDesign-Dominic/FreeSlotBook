rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function authUid() {
      return request.auth.uid;
    }

    function authEmail() {
      return isSignedIn() && request.auth.token.email is string
        ? request.auth.token.email
        : null;
    }

    function authEmailKey() {
      return authEmail() != null ? authEmail().lower() : null;
    }

    function userDoc(uid) {
      return /databases/$(database)/documents/users/$(uid);
    }

    function calendarDocPath(calendarId) {
      return /databases/$(database)/documents/calendars/$(calendarId);
    }

    function accessDocPath(calendarId, uid) {
      return /databases/$(database)/documents/calendars/$(calendarId)/access/$(uid);
    }

    function inviteDocPath(calendarId, uid) {
      return /databases/$(database)/documents/calendars/$(calendarId)/invites/$(uid);
    }

    function accessRequestDocPath(calendarId, uid) {
      return /databases/$(database)/documents/calendars/$(calendarId)/accessRequests/$(uid);
    }

    function isSelf(uid) {
      return isSignedIn() && authUid() == uid;
    }

    function calendarData(calendarId) {
      return get(calendarDocPath(calendarId)).data;
    }

    function calendarExists(calendarId) {
      return exists(calendarDocPath(calendarId));
    }

    function isCalendarOwner(calendarId) {
      return isSignedIn()
        && calendarExists(calendarId)
        && calendarData(calendarId).ownerUid == authUid();
    }

    function hasCalendarAccess(calendarId) {
      return isSignedIn() && exists(accessDocPath(calendarId, authUid()));
    }

    function calendarAccessRole(calendarId) {
      return hasCalendarAccess(calendarId)
        ? get(accessDocPath(calendarId, authUid())).data.role
        : null;
    }

    function isCalendarMember(calendarId) {
      return hasCalendarAccess(calendarId)
        && (calendarAccessRole(calendarId) == 'owner' || calendarAccessRole(calendarId) == 'member');
    }

    function isPublicCalendar(calendarId) {
      return calendarExists(calendarId) && calendarData(calendarId).visibility == 'public';
    }

    function isAppointmentParticipant(calendarId, appointmentId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/calendars/$(calendarId)/appointments/$(appointmentId))
        && (
          get(/databases/$(database)/documents/calendars/$(calendarId)/appointments/$(appointmentId)).data.participantUid == authUid()
          || (
            authEmailKey() != null
            && get(/databases/$(database)/documents/calendars/$(calendarId)/appointments/$(appointmentId)).data.participantEmailKey == authEmailKey()
          )
        );
    }

    function isBookedSlotParticipant(calendarId) {
      return resource.data.status == 'booked'
        && resource.data.appointmentId is string
        && isAppointmentParticipant(calendarId, resource.data.appointmentId);
    }

    function isNotificationRecipient() {
      return isSignedIn()
        && (
          (resource.data.recipientUid is string && resource.data.recipientUid == authUid())
          || (authEmailKey() != null && resource.data.recipientEmailKey == authEmailKey())
        );
    }

    function isCreatingOwnPendingRequest(calendarId, uid) {
      return isSelf(uid)
        && request.resource.data.calendarId == calendarId
        && request.resource.data.requesterUid == authUid()
        && request.resource.data.requesterEmail == authEmail()
        && request.resource.data.status == 'pending';
    }

    function isOwnerBootstrapAccess(calendarId, uid) {
      return isSelf(uid)
        && request.resource.data.calendarId == calendarId
        && request.resource.data.uid == authUid()
        && request.resource.data.role == 'owner';
    }

    function isInvitedMemberAcceptance(calendarId, uid) {
      return isSelf(uid)
        && request.resource.data.calendarId == calendarId
        && request.resource.data.uid == authUid()
        && request.resource.data.role == 'member'
        && exists(inviteDocPath(calendarId, authUid()))
        && get(inviteDocPath(calendarId, authUid())).data.status == 'pending';
    }

    function isAllowedMemberSlotBooking(calendarId) {
      return isCalendarMember(calendarId)
        && !isCalendarOwner(calendarId)
        && resource.data.status == 'available'
        && request.resource.data.status == 'booked'
        && resource.data.appointmentId == null
        && request.resource.data.appointmentId is string
        && request.resource.data.calendarId == resource.data.calendarId
        && request.resource.data.ownerUid == resource.data.ownerUid
        && request.resource.data.startsAt == resource.data.startsAt
        && request.resource.data.endsAt == resource.data.endsAt;
    }

    function isAllowedPublicSlotBooking(calendarId) {
      return isPublicCalendar(calendarId)
        && resource.data.status == 'available'
        && request.resource.data.status == 'booked'
        && resource.data.appointmentId == null
        && request.resource.data.appointmentId is string
        && request.resource.data.calendarId == resource.data.calendarId
        && request.resource.data.ownerUid == resource.data.ownerUid
        && request.resource.data.startsAt == resource.data.startsAt
        && request.resource.data.endsAt == resource.data.endsAt;
    }

    match /users/{uid} {
      allow read: if true;
      allow create, update: if isSelf(uid) && request.resource.data.uid == authUid();
      allow delete: if false;

      match /devices/{deviceId} {
        allow read, write: if isSelf(uid);
      }

      match /connectedCalendarPreferences/{calendarId} {
        allow read, write: if isSelf(uid);
      }
    }

    match /usernames/{username} {
      allow read: if true;
      allow create, update: if isSignedIn() && request.resource.data.uid == authUid();
      allow delete: if isSignedIn() && resource.data.uid == authUid();
    }

    match /emails/{emailKey} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn()
        && request.resource.data.uid == authUid()
        && request.resource.data.emailKey == emailKey
        && request.resource.data.email == authEmail();
      allow delete: if isSignedIn() && resource.data.uid == authUid();
    }

    match /calendarSlugs/{calendarSlug} {
      allow read: if true;
      allow create, update: if isSignedIn()
        && request.resource.data.calendarSlug == calendarSlug
        && request.resource.data.calendarId is string
        && isCalendarOwner(request.resource.data.calendarId);
      allow delete: if isSignedIn()
        && resource.data.calendarId is string
        && isCalendarOwner(resource.data.calendarId);
    }

    match /calendars/{calendarId} {
      allow create: if isSignedIn()
        && request.resource.data.calendarId == calendarId
        && request.resource.data.ownerUid == authUid();
      allow read: if isCalendarMember(calendarId) || isPublicCalendar(calendarId);
      allow update, delete: if isCalendarOwner(calendarId);

      match /access/{uid} {
        allow read: if isCalendarOwner(calendarId) || isSelf(uid);
        allow create: if isCalendarOwner(calendarId) || isOwnerBootstrapAccess(calendarId, uid) || isInvitedMemberAcceptance(calendarId, uid);
        allow update: if isCalendarOwner(calendarId);
        allow delete: if isCalendarOwner(calendarId) || (isSelf(uid) && resource.data.role == 'member');
      }

      match /invites/{invitedUid} {
        allow read: if isCalendarOwner(calendarId) || isSelf(invitedUid);
        allow create: if isCalendarOwner(calendarId)
          && request.resource.data.calendarId == calendarId
          && request.resource.data.invitedUid == invitedUid
          && request.resource.data.invitedByUid == authUid()
          && request.resource.data.status == 'pending';
        allow update: if isCalendarOwner(calendarId)
          || (
            isSelf(invitedUid)
            && resource.data.status == 'pending'
            && (request.resource.data.status == 'accepted' || request.resource.data.status == 'rejected')
          );
        allow delete: if isCalendarOwner(calendarId);
      }

      match /accessRequests/{uid} {
        allow read: if isCalendarOwner(calendarId) || isSelf(uid);
        allow create: if isCreatingOwnPendingRequest(calendarId, uid);
        allow update: if isCalendarOwner(calendarId)
          || (
            isSelf(uid)
            && resource.data.status == 'pending'
            && request.resource.data.status == 'cancelled'
          );
        allow delete: if isCalendarOwner(calendarId);
      }

      match /slots/{slotId} {
        allow read: if isCalendarOwner(calendarId)
          || (isCalendarMember(calendarId) && resource.data.status == 'available')
          || (isPublicCalendar(calendarId) && resource.data.status == 'available')
          || isBookedSlotParticipant(calendarId);
        allow create, delete: if isCalendarOwner(calendarId);
        allow update: if isCalendarOwner(calendarId)
          || isAllowedMemberSlotBooking(calendarId)
          || isAllowedPublicSlotBooking(calendarId);

        match /events/{eventId} {
          allow read: if isCalendarOwner(calendarId);
          allow create: if isCalendarOwner(calendarId)
            || (
              isCalendarMember(calendarId)
              && !isCalendarOwner(calendarId)
              && request.resource.data.type == 'booked'
              && request.resource.data.actorUid == authUid()
              && request.resource.data.actorRole == 'member'
            )
            || (
              isPublicCalendar(calendarId)
              && request.resource.data.type == 'booked'
              && request.resource.data.actorUid == null
              && request.resource.data.actorRole == 'guest'
            );
          allow update, delete: if isCalendarOwner(calendarId);
        }
      }

      match /appointments/{appointmentId} {
        allow read: if isCalendarOwner(calendarId)
          || isAppointmentParticipant(calendarId, appointmentId);
        allow create: if isCalendarOwner(calendarId)
          || (
            isCalendarMember(calendarId)
            && !isCalendarOwner(calendarId)
            && request.resource.data.calendarId == calendarId
            && request.resource.data.participantUid == authUid()
            && request.resource.data.bookedByUserId == authUid()
            && request.resource.data.bookedByEmail == authEmail()
            && request.resource.data.participantEmail == authEmail()
            && request.resource.data.status == 'booked'
          )
          || (
            isPublicCalendar(calendarId)
            && request.resource.data.calendarId == calendarId
            && request.resource.data.status == 'booked'
            && request.resource.data.participantUid == null
            && request.resource.data.bookedByUserId == null
            && request.resource.data.createdByUserId == null
            && request.resource.data.guestBooking == true
            && request.resource.data.termsAccepted == true
            && request.resource.data.privacyAccepted == true
            && request.resource.data.termsVersion == '2026-03-18'
            && request.resource.data.privacyVersion == '2026-03-18'
          );
        allow update, delete: if isCalendarOwner(calendarId);
      }
    }

    match /notifications/{notificationId} {
      allow read: if isNotificationRecipient()
        || (
          resource.data.calendarId is string
          && isCalendarOwner(resource.data.calendarId)
        );
      allow create: if (
          isSignedIn()
          && request.resource.data.calendarId is string
          && isCalendarOwner(request.resource.data.calendarId)
        )
        || (
          isSignedIn()
          && request.resource.data.calendarId is string
          && isCalendarMember(request.resource.data.calendarId)
          && !isCalendarOwner(request.resource.data.calendarId)
          && request.resource.data.type == 'booking_created'
        )
        || (
          request.resource.data.calendarId is string
          && isPublicCalendar(request.resource.data.calendarId)
          && (
            request.resource.data.type == 'booking_created'
            || request.resource.data.type == 'booking_confirmation'
            || request.resource.data.type == 'account_creation_invite'
          )
        );
      allow update: if isNotificationRecipient()
        || (
          resource.data.calendarId is string
          && isCalendarOwner(resource.data.calendarId)
        );
      allow delete: if false;
    }
  }
}
