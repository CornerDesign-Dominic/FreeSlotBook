rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function signedInEmail() {
      return request.auth.token.email;
    }

    function signedInEmailKey() {
      return signedInEmail().lower();
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function ownsCalendar(calendarId) {
      return isSignedIn()
        && get(/databases/$(database)/documents/calendars/$(calendarId)).data.ownerId == request.auth.uid;
    }

    function hasCalendarAccess(calendarId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/calendars/$(calendarId)/access/$(signedInEmailKey()))
        && get(/databases/$(database)/documents/calendars/$(calendarId)/access/$(signedInEmailKey())).data.status == 'approved';
    }

    function isPublicCalendar(calendarId) {
      return get(/databases/$(database)/documents/calendars/$(calendarId)).data.visibility == 'public';
    }

    function calendarOwnerEmail(calendarId) {
      return get(/databases/$(database)/documents/calendars/$(calendarId)).data.ownerEmail;
    }

    function isAllowedSlotBookingUpdate(calendarId) {
      return hasCalendarAccess(calendarId)
        && resource.data.status == 'available'
        && request.resource.data.status == 'booked'
        && resource.data.appointmentId == null
        && request.resource.data.appointmentId is string
        && request.resource.data.calendarId == resource.data.calendarId
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.startsAt == resource.data.startsAt
        && request.resource.data.endsAt == resource.data.endsAt;
    }

    function isAllowedPublicSlotBookingUpdate(calendarId) {
      return isPublicCalendar(calendarId)
        && resource.data.status == 'available'
        && request.resource.data.status == 'booked'
        && resource.data.appointmentId == null
        && request.resource.data.appointmentId is string
        && request.resource.data.calendarId == resource.data.calendarId
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.startsAt == resource.data.startsAt
        && request.resource.data.endsAt == resource.data.endsAt;
    }

    match /owners/{userId} {
      allow read, write: if isOwner(userId);

      match /devices/{deviceId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /publicCalendarSlugs/{slug} {
      allow read: if true;
      allow create, update: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.calendarId is string
        && get(/databases/$(database)/documents/calendars/$(request.resource.data.calendarId)).data.ownerId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    match /calendars/{calendarId} {
      allow create: if isOwner(calendarId)
        && request.resource.data.ownerId == request.auth.uid;
      allow read: if ownsCalendar(calendarId) || hasCalendarAccess(calendarId) || isPublicCalendar(calendarId);
      allow update, delete: if ownsCalendar(calendarId);

      match /access/{accessId} {
        allow read: if ownsCalendar(calendarId) || accessId == signedInEmailKey();
        allow create, update, delete: if ownsCalendar(calendarId);
      }

      match /requests/{requestId} {
        allow read: if ownsCalendar(calendarId) || requestId == signedInEmailKey();
        allow create: if isSignedIn()
          && requestId == signedInEmailKey()
          && request.resource.data.requesterEmailKey == signedInEmailKey();
        allow update, delete: if ownsCalendar(calendarId);
      }

      match /slots/{slotId} {
        allow read: if ownsCalendar(calendarId)
          || hasCalendarAccess(calendarId)
          || (isPublicCalendar(calendarId) && resource.data.status == 'available');
        allow create, delete: if ownsCalendar(calendarId);
        allow update: if ownsCalendar(calendarId)
          || isAllowedSlotBookingUpdate(calendarId)
          || isAllowedPublicSlotBookingUpdate(calendarId);

        match /events/{eventId} {
          allow read: if ownsCalendar(calendarId);
          allow create, update, delete: if ownsCalendar(calendarId)
            || (hasCalendarAccess(calendarId)
              && request.resource.data.type == 'booked'
              && request.resource.data.actorUid == request.auth.uid
              && request.resource.data.actorRole == 'contact')
            || (isPublicCalendar(calendarId)
              && request.resource.data.type == 'booked'
              && request.resource.data.actorUid == null
              && request.resource.data.actorRole == 'contact');
        }
      }

      match /appointments/{appointmentId} {
        allow read: if ownsCalendar(calendarId)
          || (isSignedIn() && resource.data.participantEmail == signedInEmail());
        allow create: if ownsCalendar(calendarId)
          || (hasCalendarAccess(calendarId)
            && request.resource.data.participantEmail == signedInEmail()
            && request.resource.data.bookedByEmail == signedInEmail()
            && request.resource.data.bookedByUserId == request.auth.uid
            && request.resource.data.status == 'booked')
          || (isPublicCalendar(calendarId)
            && request.resource.data.status == 'booked'
            && request.resource.data.bookedByUserId == null
            && request.resource.data.createdByUserId == null
            && request.resource.data.guestBooking == true
            && request.resource.data.termsAccepted == true
            && request.resource.data.termsAcceptedAt is timestamp
            && request.resource.data.termsVersion == '2026-03-18'
            && request.resource.data.privacyAccepted == true
            && request.resource.data.privacyAcceptedAt is timestamp
            && request.resource.data.privacyVersion == '2026-03-18'
            && request.resource.data.bookedByEmail == request.resource.data.participantEmail
            && request.resource.data.bookedByEmailKey == request.resource.data.participantEmailKey);
        allow update, delete: if ownsCalendar(calendarId);
      }

      match /notifications/{notificationId} {
        allow read: if ownsCalendar(calendarId)
          || (isSignedIn() && resource.data.recipientEmailKey == signedInEmailKey());
        allow create: if ownsCalendar(calendarId)
          || (hasCalendarAccess(calendarId)
            && request.resource.data.recipientEmailKey == get(/databases/$(database)/documents/calendars/$(calendarId)).data.ownerEmailKey
            && request.resource.data.type == 'booking_created'
            && request.resource.data.channel == 'in_app')
          || (isPublicCalendar(calendarId)
            && (
              (request.resource.data.type == 'booking_created'
                && request.resource.data.recipientEmailKey == get(/databases/$(database)/documents/calendars/$(calendarId)).data.ownerEmailKey
                && (request.resource.data.channel == 'in_app' || request.resource.data.channel == 'email'))
              || ((request.resource.data.type == 'booking_confirmation'
                  || request.resource.data.type == 'account_creation_invite')
                && request.resource.data.channel == 'email')
            ));
        allow update, delete: if ownsCalendar(calendarId)
          || (isSignedIn() && resource.data.recipientEmailKey == signedInEmailKey());
      }
    }
  }
}
